{
    "$schema": "https://opencode.ai/config.json",
    "share": "disabled",
    "autoupdate": true,
        "server": {
        "port": 4096,
        "hostname": "0.0.0.0",
        "mdns": true,
        "mdnsDomain": "myproject.local",
        "cors": ["http://localhost:5173"]
    },
    "permission": {
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    },
    "lsp": true,
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true,
            "timeout": 10000,
        }
    },
    "formatter": {
        "python-black": {
            "command": ["black", "$FILE"],
            "environment": {
            "PYTHON_ENV": "development"
            },
            "extensions": [".py"]
        }
    },
    "compaction": { // Default configuration from https://opencode.ai/docs/config/#compaction
        "auto": true,
        "prune": true,
        "reserved": 10000
    },
    "watcher": {
        "ignore": ["node_modules/**", "dist/**", ".git/**"]
    },
    "plugin": [],
    "instructions": [],
    "disabled_providers": [],
}